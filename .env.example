# ================================
# GHF Agency — Backend .env
# ================================

# Server
PORT=5000
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/ghf_agency?sslmode=require"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Clerk (optionnel - pour auth frontend Next.js)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=ghf-agency
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Firebase Admin (FCM)
FIREBASE_PROJECT_ID=ghf-agency
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@ghf-agency.iam.gserviceaccount.com

# CORS
FRONTEND_URL=http://localhost:3000
